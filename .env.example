# =============================================================
# Ebbe — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# =============================================================

# --- Required ---

# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string

# Your domain (or http://localhost for local dev)
CORS_ORIGIN=https://yourdomain.com

# Email for Caddy's Let's Encrypt certificates (only needed for HTTPS)
CADDY_EMAIL=your@email.com

# Your domain for Caddy (e.g. ebbe.yourdomain.com or localhost)
CADDY_HOST=ebbe.yourdomain.com

# http for local/home use, https for a public domain with auto-TLS
CADDY_SCHEME=https

# --- Optional: AI modules ---
# Only needed if you enable the AI module in parent settings
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Optional: Backup ---
# Litestream continuous backup destination.
# Requires running with: docker compose --profile backup up
# Examples:
#   s3://my-bucket/ebbe
#   file:///backups/ebbe
LITESTREAM_REPLICA_URL=

# --- Development only ---
NODE_ENV=production
